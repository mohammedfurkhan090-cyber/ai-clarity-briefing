# Copy this file to .env and add your Groq and Tavily API keys.
# Get Groq at: https://console.groq.com/keys
# Get Tavily at: https://app.tavily.com

GROQ_API_KEY=your_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
TAVILY_API_KEY=your_tavily_api_key_here

# Optional overrides
# BRIEFING_CACHE_SECONDS=900
